# ── Required ───────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Supabase (required for persistent checkpointer + analytics) ────────────────
# Use the DIRECT connection string (port 5432), not the pooler (port 6543)
# Supabase Dashboard → Settings → Database → Connection string → URI
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Per-agent model override (optional — each agent has a hardcoded default) ──
SEARCH_RESPONSE_MODEL=anthropic/claude-sonnet-4-20250514
SUMMARIZATION_TRIGGER_TOKENS=90000
SUMMARIZATION_KEEP_MESSAGES=5

# ── Retry control ──────────────────────────────────────────────────────────────
STRUCTURED_OUTPUT_MAX_RETRIES=3

# ── LangSmith (optional) ───────────────────────────────────────────────────────
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=bible-copilot
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
